{"metadata":{"display_name":"AstrBot Статистика сообщений","short_desc":"Отслеживайте количество сообщений с таблицами лидеров","desc":"Отслеживание сообщений участников группы. Поддерживает ежедневные/еженедельные/ежемесячные/годовые рейтинги, анализ титулов через LLM и автоматическую отправку."},"config":{"theme":{"description":"Тема таблицы лидеров","hint":"Визуальная тема для изображения рейтинга"},"auto_theme_switch":{"description":"Авто-переключение темы","hint":"Автоматически переключать между светлой/тёмной темой"},"theme_switch_light_time":{"description":"Начало светлой темы","hint":"Формат ЧЧ:ММ, например 06:00"},"theme_switch_dark_time":{"description":"Начало тёмной темы","hint":"Формат ЧЧ:ММ, например 18:00"},"detailed_logging_enabled":{"description":"Детальное логирование","hint":"Отключите для уменьшения количества логов"},"rand":{"description":"Количество в рейтинге","hint":"Рекомендуется 5-50"},"if_send_pic":{"description":"Режим вывода","hint":"Изображение красивее, текст экономит ресурсы"},"timer_enabled":{"description":"Автоматическая отправка","hint":"Отправлять рейтинг по расписанию"},"timer_push_time":{"description":"Время отправки","hint":"Поддерживает HH:MM или cron формат"},"timer_target_groups":{"description":"Целевые группы","hint":"ID групп для получения рассылки"},"timer_rank_type":{"description":"Тип рейтинга","hint":"Тип таблицы лидеров для отправки"},"milestone_enabled":{"description":"Отправка достижений","hint":"Авто-отправка при достижении порога сообщений"},"milestone_targets":{"description":"Пороги достижений","hint":"например 666, 1000"},"blocked_users":{"description":"Заблокированные пользователи","hint":"Пользователи исключены из статистики"},"blocked_groups":{"description":"Заблокированные группы","hint":"Группы исключены из статистики"},"llm_enabled":{"description":"LLM анализ титулов","hint":"Генерировать персонализированные титулы через LLM"},"llm_provider_id":{"description":"LLM Provider ID","hint":"Оставьте пустым для стандартного"},"llm_system_prompt":{"description":"Промпт для титулов","hint":"Настройте стиль и цвета генерации"},"llm_max_retries":{"description":"Повторы LLM","hint":"Количество повторов при ошибке"},"llm_min_daily_messages":{"description":"Мин. сообщений в день","hint":"Пользователи ниже порога не получат титулы"},"llm_enable_on_manual":{"description":"LLM при ручном запросе","hint":"Также генерировать титулы при ручных запросах"}}}
